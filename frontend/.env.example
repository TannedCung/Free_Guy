# Frontend environment variables for the Vite/React application.
# Copy this file to .env.local for local overrides (never commit .env.local).
# In production (Vercel), set these as environment variables in the Vercel
# project dashboard under Settings → Environment Variables.

# ── Backend API ───────────────────────────────────────────────────────────────
# Absolute origin of the Django backend.  Leave empty (or omit) in local
# development — the Vite dev-server proxy will forward /api/* to localhost:8000.
#
# Production example:
#   VITE_API_BASE_URL=https://api.your-backend.com
VITE_API_BASE_URL=

# ── WebSocket ─────────────────────────────────────────────────────────────────
# WebSocket base URL for the Django Channels server.  Must use the ws:// or
# wss:// scheme.  Leave empty in local development — the hook derives the URL
# from the current page origin automatically.
#
# Production example (note wss:// for HTTPS backends):
#   VITE_WS_BASE_URL=wss://api.your-backend.com
VITE_WS_BASE_URL=
