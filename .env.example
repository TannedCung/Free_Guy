# Copy this file to .env and fill in the values for your environment.
# Never commit .env to source control.

# ── Django ────────────────────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Environment selector: 'development' (default) or 'production'
# Controls which settings module is loaded (settings/development.py or settings/production.py)
DJANGO_ENV=development

# Comma-separated list of allowed hostnames — required in production, ignored in development
# e.g. example.com,www.example.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default for local dev — omit DATABASE_URL to use SQLite)
# DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL example:
# DATABASE_URL=postgres://user:password@localhost:5432/free_guy_db

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Agent identity ────────────────────────────────────────────────────────────
KEY_OWNER=YourName

# ── Docker / PostgreSQL (used by docker-compose) ──────────────────────────────
POSTGRES_USER=freeguy
POSTGRES_PASSWORD=changeme
POSTGRES_DB=free_guy_db
